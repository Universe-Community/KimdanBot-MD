# Biblioteca/libros (MongoDB + Mongoose). Sin esto, los comandos de libros
# avisan que falta configuración y el resto del bot funciona igual.
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/Kim?retryWrites=true&w=majority

# Capa de traducción opcional (idioma por usuario/grupo/global).
# Por defecto usa el endpoint público de LibreTranslate.
# LIBRETRANSLATE_URL=https://libretranslate.com/translate
# BOT_LANG=es

# ── Logs ─────────────────────────────────────────────────────────────
# Nivel de detalle de la consola: silent | error | warn | info | debug
# (tiene prioridad sobre global.logLevel de settings.js)
# LOG_LEVEL=info

# ── Mantenimiento de integridad del authFolder (kim/authcare.js) ────
# NO poda claves por antigüedad (eso corrompía la sesión). Solo sanea
# archivos corruptos/vacíos. Una carpeta grande es normal y sana.
# AUTHCARE_ENABLED=true
# AUTHCARE_INTERVAL_HOURS=3
# AUTHCARE_GRACE_MINUTES=5
# AUTHCARE_DEEP_STARTUP=true
# Solo para la limpieza manual `.authclean --hard`:
# AUTHCARE_HARD_SESSION_DAYS=90
# AUTHCARE_HARD_SENDERKEY_DAYS=60

# ── Sub-bots temporales ──────────────────────────────────────────────
# Las licencias (permanente/temporal, expiración) se guardan en MongoDB
# usando la misma MONGODB_URI de arriba, en la colección `Kim.SubBots`.
# Sin MONGODB_URI el sistema sigue funcionando con `subbots/licenses.json`.
# Intervalo del barrido de expiración en minutos (por defecto 10):
# SUBBOT_EXPIRY_INTERVAL_MIN=10
