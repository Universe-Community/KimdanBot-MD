# Biblioteca/libros (MongoDB + Mongoose). Sin esto, los comandos de libros
# avisan que falta configuración y el resto del bot funciona igual.
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/Kim?retryWrites=true&w=majority

# Capa de traducción opcional (idioma por usuario/grupo/global).
# Por defecto usa el endpoint público de LibreTranslate.
# LIBRETRANSLATE_URL=https://libretranslate.com/translate
# BOT_LANG=es

# ── Logs ─────────────────────────────────────────────────────────────
# Nivel de detalle de la consola: silent | error | warn | info | debug
# (tiene prioridad sobre global.logLevel de settings.js)
# LOG_LEVEL=info

# ── Mantenimiento automático del authFolder (kim/authcare.js) ───────
# Poda archivos de sesión obsoletos SIN tocar creds.json ni AppState Keys.
# AUTHCARE_ENABLED=true
# AUTHCARE_INTERVAL_HOURS=12
# AUTHCARE_MIN_FILES=300
# AUTHCARE_PREKEY_DAYS=30
# AUTHCARE_SESSION_DAYS=21
# AUTHCARE_SENDERKEY_DAYS=14
